NODE_ENV=production
PORT=8080

# Comma-separated origins allowed to connect during development.
# In production, set this to your public HTTPS domain.
CORS_ORIGIN=http://localhost:5173

# Identity relay limits. Queues contain encrypted envelopes only.
MAX_QUEUE_PER_USER=100
MAX_REGISTERED_USERS=200
PRESENCE_IDLE_TTL_MS=86400000

# Optional: serve the built frontend from Express in production.
# Example after copying frontend/dist to backend/public:
# FRONTEND_DIST=public
FRONTEND_DIST=public
